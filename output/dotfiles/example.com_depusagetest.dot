digraph "" {
  rankdir=LR;
  "n1" [color="#484061", label="init", shape="box", style="solid", tooltip="example.com/depusagetest.init"];
  "n2" [color="#484061", label="triangle", shape="box", style="solid", tooltip="example.com/depusagetest.triangle"];
  "n3" [color="#484061", label="callOthers", shape="box", style="solid", tooltip="example.com/depusagetest.callOthers"];
  "n4" [color="#484061", label="main", shape="box", style="solid", tooltip="example.com/depusagetest.main"];
  "n3" -> "n2" [arrowhead="normal", color="#000000", style="solid", tooltip="return triangle"];
  "n4" -> "n2" [arrowhead="normal", color="#000000", style="solid", tooltip="*storedFn = triangle"];
}
