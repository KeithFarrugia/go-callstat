digraph "" {
  rankdir=LR;
  "n0" [color="#484061", label="<root>", shape="box", style="solid"];
  "n1" [color="#484061", label="main", shape="box", style="solid", tooltip="example.com/depusagetest.main"];
  "n10" [color="#484061", label="init", shape="box", style="solid", tooltip="example.com/depusagetest.init"];
  "n11" [color="#484061", label="init", shape="box", style="solid", tooltip="example.com/depusagetest/something.init"];
  "n2" [color="#484061", label="worker", shape="box", style="solid", tooltip="example.com/depusagetest.worker"];
  "n3" [color="#6c3636", label="worker$1", shape="box", style="dashed", tooltip="example.com/depusagetest.worker$1"];
  "n4" [color="#484061", label="square", shape="box", style="solid", tooltip="example.com/depusagetest.square"];
  "n5" [color="#484061", label="mul", shape="box", style="solid", tooltip="example.com/depusagetest.mul"];
  "n6" [color="#6c3636", label="main$1", shape="box", style="dashed", tooltip="example.com/depusagetest.main$1"];
  "n7" [color="#484061", label="add", shape="box", style="solid", tooltip="example.com/depusagetest.add"];
  "n8" [color="#6c3636", label="main$2", shape="box", style="dashed", tooltip="example.com/depusagetest.main$2"];
  "n9" [color="#484061", label="maybePanic", shape="box", style="solid", tooltip="example.com/depusagetest.maybePanic"];
  "n1" -> "n2" [arrowhead="dot", color="#1f77b4", label="go", style="dashed", tooltip="concurrent go worker(1:int, t4, t5)"];
  "n1" -> "n6" [arrowhead="dot", color="#1f77b4", label="go", style="dashed", tooltip="concurrent go t9()"];
  "n1" -> "n8" [arrowhead="normal", color="#2b2b2b", label="call", style="solid", tooltip="main$2(t12)"];
  "n4" -> "n5" [arrowhead="normal", color="#2b2b2b", label="call", style="solid", tooltip="mul(x, x)"];
  "n6" -> "n7" [arrowhead="normal", color="#2b2b2b", label="call", style="solid", tooltip="add(2:int, 3:int)"];
  "n6" -> "n0" [arrowhead="normal", color="black", label="", style="solid", tooltip="send t1 <- t2"];
  "n8" -> "n9" [arrowhead="normal", color="#2b2b2b", label="call", style="solid", tooltip="maybePanic(v)"];
  "n9" -> "n0" [arrowhead="tee", color="#d62728", label="panic", style="bold", tooltip="panic t1"];
  "n2" -> "n3" [arrowhead="diamond", color="#9467bd", label="defer", style="dotted", tooltip="deferred defer t1()"];
  "n2" -> "n4" [arrowhead="normal", color="#2b2b2b", label="call", style="solid", tooltip="square(t4)"];
  "n2" -> "n0" [arrowhead="normal", color="black", label="", style="solid", tooltip="send results <- t5"];
}
